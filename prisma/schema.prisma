generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SiteContentRecord {
  id        String   @id @default("main")
  content   Json
  updatedAt DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  folder    String   @default("uploads")
  mimeType  String
  size      Int      @default(0)
  createdAt DateTime @default(now())
}

model ContentBackup {
  id        String   @id @default(cuid())
  label     String?
  content   Json
  createdAt DateTime @default(now())
}

model Room {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  price       Int
  image       String?
  bookings    Booking[]
}

model Booking {
  id              Int       @id @default(autoincrement())
  name            String
  email           String
  phone           String    @default("")
  country         String    @default("")
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  children        Int       @default(0)
  roomQuantity    Int       @default(1)
  roomSlug        String    @default("")
  roomName        String    @default("")
  breakfast       String    @default("room-only")
  specialRequests String    @default("")
  paymentMethod   String    @default("hotel")
  totalAmount     Int       @default(0)
  nights          Int       @default(1)
  status          String    @default("pending")
  paymentStatus   String    @default("unpaid")
  transactionId   String?
  createdAt       DateTime  @default(now())
  roomId          Int?
  room            Room?     @relation(fields: [roomId], references: [id])
}
