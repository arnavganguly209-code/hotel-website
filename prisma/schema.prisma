generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SiteContentRecord {
  id        String   @id @default("main")
  content   Json
  updatedAt DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  folder    String   @default("uploads")
  mimeType  String
  size      Int      @default(0)
  createdAt DateTime @default(now())
}

model ContentBackup {
  id        String   @id @default(cuid())
  label     String?
  content   Json
  createdAt DateTime @default(now())
}

model Room {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String
  price       Int
  image       String?
  bookings    Booking[]
}

model Booking {
  id              Int       @id @default(autoincrement())
  name            String
  email           String
  phone           String    @default("")
  whatsapp        String    @default("")
  countryCode     String    @default("")
  country         String    @default("")
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  children        Int       @default(0)
  roomQuantity    Int       @default(1)
  roomSlug        String    @default("")
  roomName        String    @default("")
  breakfast       String    @default("with-breakfast")
  roomNumber      String    @default("")
  specialRequests String    @default("")
  promoCode       String    @default("")
  arrivalTime     String    @default("")
  flightNumber    String    @default("")
  notes           String    @default("")
  remarks         String    @default("")
  source          String    @default("online")
  paymentMethod   String    @default("hotel")
  cardLast4       String    @default("")
  totalAmount     Int       @default(0)
  nights          Int       @default(1)
  status          String    @default("pending")
  paymentStatus   String    @default("unpaid")
  transactionId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roomId          Int?
  room            Room?     @relation(fields: [roomId], references: [id])

  @@index([roomSlug, checkIn, checkOut])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model EventInquiry {
  id             Int       @id @default(autoincrement())
  name           String
  email          String
  phone          String    @default("")
  country        String    @default("")
  company        String    @default("")
  eventType      String    @default("")
  guests         Int       @default(0)
  eventDate      DateTime?
  eventTime      String    @default("")
  budget         String    @default("")
  specialRequest String    @default("")
  attachmentUrl  String    @default("")
  status         String    @default("new")
  adminReply     String    @default("")
  createdAt      DateTime  @default(now())
}

model ContactEnquiry {
  id                   Int       @id @default(autoincrement())
  fullName             String
  email                String
  phone                String    @default("")
  country              String    @default("")
  arrivalDate          DateTime?
  departureDate        DateTime?
  guests               Int       @default(1)
  adults               Int       @default(1)
  children             Int       @default(0)
  roomPreference       String    @default("")
  bookingType          String    @default("General Inquiry")
  preferredContact     String    @default("Email")
  budget               String    @default("")
  specialRequest       String    @default("")
  message              String    @default("")
  attachmentUrl        String    @default("")
  consent              Boolean   @default(false)
  status               String    @default("new")
  adminNotes           String    @default("")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model DiningReservation {
  id              Int       @id @default(autoincrement())
  referenceNumber String    @unique
  fullName        String
  email           String
  phone           String    @default("")
  country         String    @default("")
  restaurant      String
  reservationDate DateTime?
  reservationTime String    @default("")
  adults          Int       @default(2)
  children        Int       @default(0)
  specialOccasion String    @default("")
  specialRequest  String    @default("")
  consent         Boolean   @default(false)
  status          String    @default("new")
  adminNotes      String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdminUser {
  id                 String         @id @default(cuid())
  username           String         @unique
  passwordHash       String
  passwordChangedAt  DateTime       @default(now())
  createdAt          DateTime       @default(now())
  lastLoginAt        DateTime?
  failedAttempts     Int            @default(0)
  lockedUntil        DateTime?
  sessions           AdminSession[]
  loginEvents        AdminLoginEvent[]
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  ip        String    @default("")
  userAgent String    @default("")

  @@index([userId])
  @@index([expiresAt])
}

model AdminLoginEvent {
  id        String    @id @default(cuid())
  userId    String?
  user      AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String    @default("")
  success   Boolean
  ip        String    @default("")
  userAgent String    @default("")
  createdAt DateTime  @default(now())

  @@index([createdAt])
}

model RoomInventory {
  id         String   @id @default(cuid())
  roomSlug   String   @unique
  totalRooms Int      @default(1)
  overrides  Json?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model RoomUnit {
  id         String   @id @default(cuid())
  roomSlug   String
  roomNumber String
  status     String   @default("available") // available | occupied | maintenance
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([roomSlug, roomNumber])
  @@index([roomSlug, status])
}

model RoomBlock {
  id        String   @id @default(cuid())
  roomSlug  String
  startDate DateTime
  endDate   DateTime
  reason    String   @default("other")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomSlug, startDate, endDate])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model SpaInquiry {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String
  phone          String    @default("")
  preferredDate  DateTime?
  preferredTime  String    @default("")
  treatment      String    @default("")
  guests         Int       @default(1)
  specialRequest String    @default("")
  status         String    @default("new")
  adminNotes     String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SiteVisitDay {
  id        String   @id @default(cuid())
  day       DateTime @unique @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
