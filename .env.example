# Orbit CMS (server-side only)
ORBIT_ADMIN_PASSWORD=your-secure-key-here

# PostgreSQL on the VPS (localhost)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/hotel_thamel_park?schema=public

# Public site URL — use http:// during testing; switch to https:// after SSL
NEXT_PUBLIC_SITE_URL=http://YOUR_VPS_IP_OR_DOMAIN
SITE_URL=http://YOUR_VPS_IP_OR_DOMAIN

# Orbit local uploads (absolute path on Hostinger VPS). Served by /uploads/* route.
# UPLOADS_ROOT=/var/www/hotel-website/public/uploads

# Cookie security:
# - HTTP testing: COOKIE_SECURE=false (or leave unset with http:// SITE_URL)
# - After HTTPS (Nginx TLS): COOKIE_SECURE=true  OR  set SITE_URL to https://...
# COOKIE_SECURE=false
# TRUST_PROXY_HTTPS=true

# Contact enquiry emails (optional — enquiries still save to DB without SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Hotel Thamel Park <noreply@hotelthamelpark.com>"
